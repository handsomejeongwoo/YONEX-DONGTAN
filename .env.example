# 요넥스 동탄점 웹 — 환경변수 예시
# 실제 값은 .env(.local) 에만 넣고 절대 커밋하지 마세요. 코드에 하드코딩 금지.
#
# 이번 단계에서는 아래 변수가 없어도 사이트가 정상 동작합니다(정적 링크 카드).
# 향후 공식 API를 붙일 때만 채우면 됩니다.

# --- Instagram (Meta Graph API, 향후 연동용) ---
# Business/Creator 계정 + Facebook Page 연결 + 장기 액세스 토큰 필요.
INSTAGRAM_PROVIDER=static
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# --- Naver 스마트스토어 / 커머스 (공식 제휴·상품 API, 향후 연동용) ---
SHOP_PROVIDER=static
NAVER_COMMERCE_CLIENT_ID=
NAVER_COMMERCE_CLIENT_SECRET=

# --- Naver 지도 (Maps JS API v3, 오시는 길) ---
# 네이버 클라우드 플랫폼 콘솔 > Services > Maps > Application 등록 후 발급되는 Client ID.
# NEXT_PUBLIC_ 접두사라 클라이언트에 노출됨(공개 키). 반드시 콘솔에서 Web 서비스 URL(도메인)을 제한할 것.
# 정적 export라 값은 빌드 시점에 인라인됨 → 값 바꾸면 재빌드 필요. 없으면 지도 대신 링크 카드로 폴백.
NEXT_PUBLIC_NAVER_MAP_CLIENT_ID=
# 스크립트 인증 파라미터명. 신규 키는 ncpKeyId(기본값), 구 키는 ncpClientId 로 바꿔서 사용.
NEXT_PUBLIC_NAVER_MAP_KEY_PARAM=ncpKeyId
